// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  password      String
  role          UserRole
  wallet_balance Decimal @default(0.00) @db.Decimal(10, 2)
  phone         String?
  location      String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  // Relations
  energyListings EnergyListing[]
  purchases      Transaction[]       @relation("BuyerTransactions")
  sales          Transaction[]       @relation("SellerTransactions")
  investments    Investment[]
  projects       Project[]
  ratings        Rating[]

  @@map("users")
}

model EnergyListing {
  id              String    @id @default(cuid())
  seller_id       String
  energy_type     EnergyType
  capacity_kwh    Decimal   @db.Decimal(10, 2)
  price_per_kwh   Decimal   @db.Decimal(10, 2)
  location        String
  available_units Decimal   @db.Decimal(10, 2)
  description     String?
  is_active       Boolean   @default(true)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  // Relations
  seller        User          @relation(fields: [seller_id], references: [id], onDelete: Cascade)
  transactions  Transaction[]

  @@map("energy_listings")
}

model Transaction {
  id            String           @id @default(cuid())
  buyer_id      String
  seller_id     String
  listing_id    String
  energy_units  Decimal          @db.Decimal(10, 2)
  price_per_kwh Decimal          @db.Decimal(10, 2)
  total_price   Decimal          @db.Decimal(10, 2)
  status        TransactionStatus @default(PENDING)
  commission    Decimal          @default(0.03) @db.Decimal(5, 4) // 3% platform commission
  created_at    DateTime         @default(now())
  completed_at  DateTime?

  // Relations
  buyer   User           @relation("BuyerTransactions", fields: [buyer_id], references: [id], onDelete: Cascade)
  seller  User           @relation("SellerTransactions", fields: [seller_id], references: [id], onDelete: Cascade)
  listing EnergyListing  @relation(fields: [listing_id], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model Project {
  id                String     @id @default(cuid())
  seller_id         String
  project_name      String
  description       String
  total_required    Decimal    @db.Decimal(12, 2)
  current_funding   Decimal    @default(0.00) @db.Decimal(12, 2)
  roi_percentage    Decimal    @db.Decimal(5, 2)
  duration_months   Int
  risk_level        RiskLevel
  location          String
  energy_type       EnergyType
  is_active         Boolean    @default(true)
  created_at        DateTime   @default(now())
  updated_at        DateTime   @updatedAt

  // Relations
  seller      User         @relation(fields: [seller_id], references: [id], onDelete: Cascade)
  investments Investment[]

  @@map("projects")
}

model Investment {
  id               String    @id @default(cuid())
  investor_id      String
  project_id       String
  amount_invested  Decimal   @db.Decimal(12, 2)
  roi_percentage   Decimal   @db.Decimal(5, 2)
  returns_generated Decimal  @default(0.00) @db.Decimal(12, 2)
  service_fee      Decimal   @default(0.01) @db.Decimal(5, 4) // 1% investment service fee
  status           InvestmentStatus @default(ACTIVE)
  created_at       DateTime  @default(now())
  matured_at       DateTime?

  // Relations
  investor User    @relation(fields: [investor_id], references: [id], onDelete: Cascade)
  project  Project @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@map("investments")
}

model Rating {
  id         String     @id @default(cuid())
  user_id    String
  target_id  String     // User being rated
  rating     Int        @db.SmallInt // 1-5
  comment    String?
  created_at DateTime   @default(now())

  // Relations
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, target_id])
  @@map("ratings")
}

// Enums
enum UserRole {
  SELLER
  BUYER
  INVESTOR
}

enum EnergyType {
  SOLAR
  WIND
  BIOGAS
  HYDRO
  GEOTHERMAL
}

enum TransactionStatus {
  PENDING
  COMPLETED
  CANCELLED
  REFUNDED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum InvestmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}
